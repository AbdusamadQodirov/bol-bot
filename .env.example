# Telegram bot token (BotFather'dan @BotFather → /newbot)
BOL_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic API kaliti (qo'lyozma aniqlash uchun)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Log darajasi: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log fayl yo'li (bo'sh bo'lsa, faqat konsolga)
LOG_FILE=logs/bol_bot.log

# Audit log uchun SQLite ma'lumotlar bazasi
DB_PATH=data/bol_bot.db

# Rate limit: bir foydalanuvchi uchun
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_DAY=100

# Admin Telegram ID'lar (vergul bilan ajratilgan). Birinchi ID bot egasi.
ADMIN_IDS=

# Whitelist rejimi: true bo'lsa, faqat ALLOWED_USER_IDS dagilar foydalana oladi
WHITELIST_MODE=false
ALLOWED_USER_IDS=

# Standart til: uz, en, ru
DEFAULT_LANGUAGE=uz

# Maksimal fayl o'lchami (MB)
MAX_FILE_SIZE_MB=20

# OCR til(lari): "eng" yoki "eng+rus" va h.k.
TESSERACT_LANG=eng

# Vision rejimi yoqilganmi (false bo'lsa, faqat OCR ishlatiladi)
ENABLE_VISION=true

# Hujjat hash bo'yicha kesh (qayta yuklashda OCR/vision'ni o'tkazib yuborish)
ENABLE_CACHE=true
CACHE_DIR=data/cache

# Sentry DSN (ixtiyoriy, production error tracking)
SENTRY_DSN=
